# Copy this file to ".env" and fill in real values.
# server.js will run with insecure fallbacks if these are missing, but
# you should always set them yourself — especially before deploying.

# Your MongoDB connection string (MongoDB Atlas or local mongod)
MONGO_URI=mongodb://localhost:27017/tripx

# A long, random, secret string used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Port the server listens on. Most hosting platforms (Render, Railway, etc.)
# set this automatically — you usually don't need to change it.
PORT=3000
